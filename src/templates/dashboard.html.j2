<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Research Feed</title>
<style>
  :root {
    --bg: #fafafa;
    --surface: #ffffff;
    --text: #1a1a1a;
    --muted: #6b7280;
    --border: #e5e7eb;
    --accent: #2563eb;
    --tier-high-bg: #fee2e2;
    --tier-high-fg: #991b1b;
    --tier-medium-bg: #fef3c7;
    --tier-medium-fg: #92400e;
    --tier-low-bg: #e0e7ff;
    --tier-low-fg: #3730a3;
    --chip-bg: #f3f4f6;
    --chip-fg: #374151;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0f172a;
      --surface: #1e293b;
      --text: #f1f5f9;
      --muted: #94a3b8;
      --border: #334155;
      --accent: #60a5fa;
      --tier-high-bg: #7f1d1d;
      --tier-high-fg: #fecaca;
      --tier-medium-bg: #78350f;
      --tier-medium-fg: #fde68a;
      --tier-low-bg: #312e81;
      --tier-low-fg: #c7d2fe;
      --chip-bg: #334155;
      --chip-fg: #cbd5e1;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
  }
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 1rem;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .container { max-width: 960px; margin: 0 auto; }
  h1 { margin: 0 0 0.25rem; font-size: 1.5rem; }
  .meta { color: var(--muted); font-size: 0.875rem; }
  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    align-items: center;
  }
  .tier-btn {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 9999px;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.15s;
  }
  .tier-btn:hover { border-color: var(--accent); }
  .tier-btn.active {
    background: var(--accent);
    color: #ffffff;
    border-color: var(--accent);
  }
  #search {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background: var(--surface);
    color: var(--text);
    font-size: 0.9rem;
  }
  #search:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  main { padding: 1.5rem 1rem; }
  .paper {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .paper-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .paper-title {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.35;
  }
  .paper-title a { color: var(--text); text-decoration: none; }
  .paper-title a:hover { color: var(--accent); text-decoration: underline; }
  .tier-badge {
    flex-shrink: 0;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .tier-badge.high { background: var(--tier-high-bg); color: var(--tier-high-fg); }
  .tier-badge.medium { background: var(--tier-medium-bg); color: var(--tier-medium-fg); }
  .tier-badge.low { background: var(--tier-low-bg); color: var(--tier-low-fg); }
  .paper-meta {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0.25rem 0 0.5rem;
  }
  .paper-meta .journal { font-style: italic; }
  .paper-meta .dot { margin: 0 0.4rem; }
  .paper-abstract {
    margin: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text);
    max-height: 4.5em;
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }
  .paper-abstract.expanded { max-height: none; }
  .paper-abstract:not(.expanded)::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5em;
    background: linear-gradient(transparent, var(--surface));
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }
  .chip {
    font-size: 0.7rem;
    padding: 0.15rem 0.55rem;
    background: var(--chip-bg);
    color: var(--chip-fg);
    border-radius: 9999px;
  }
  .score-detail {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }
  #empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--muted);
  }
  footer {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--muted);
    font-size: 0.8rem;
  }
</style>
</head>
<body>
<header>
  <div class="container">
    <h1>Research Feed</h1>
    <div class="meta" id="meta-line">
      Updated {{ updated_human }} &middot; {{ count }} papers
      &middot; {{ tier_counts.high }} must-read
      &middot; {{ tier_counts.medium }} worth scanning
      &middot; {{ tier_counts.low }} on the radar
      &middot; scored against {{ library_size }} library papers
    </div>
    <div class="controls">
      <button class="tier-btn active" data-tier="all">All ({{ count }})</button>
      <button class="tier-btn" data-tier="high">Must-read ({{ tier_counts.high }})</button>
      <button class="tier-btn" data-tier="medium">Worth scanning ({{ tier_counts.medium }})</button>
      <button class="tier-btn" data-tier="low">On the radar ({{ tier_counts.low }})</button>
      <input id="search" type="search" placeholder="Search title, abstract, authors, journal...">
    </div>
  </div>
</header>
<main>
  <div class="container" id="paper-list"></div>
  <div class="container" id="empty" style="display:none;">No papers match your filter.</div>
</main>
<footer>
  <div class="container">
    Auto-generated from {{ feeds|length }} feeds &middot;
    <a href="papers.json">raw JSON</a>
  </div>
</footer>

<script type="application/json" id="papers-data">{{ papers_json|safe }}</script>
<script>
(function () {
  const raw = document.getElementById('papers-data').textContent;
  const papers = JSON.parse(raw);
  const list = document.getElementById('paper-list');
  const empty = document.getElementById('empty');
  const search = document.getElementById('search');
  let activeTier = 'all';
  let searchTerm = '';

  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatAuthors(authors) {
    if (!authors || !authors.length) return '';
    if (authors.length <= 3) return authors.join(', ');
    return authors.slice(0, 3).join(', ') + ' et al.';
  }

  function render() {
    const term = searchTerm.toLowerCase();
    const filtered = papers.filter(function (p) {
      if (activeTier !== 'all' && p.tier !== activeTier) return false;
      if (!term) return true;
      const hay = (
        (p.title || '') + ' ' +
        (p.abstract || '') + ' ' +
        (p.journal || '') + ' ' +
        (p.authors || []).join(' ')
      ).toLowerCase();
      return hay.indexOf(term) !== -1;
    });

    if (!filtered.length) {
      list.innerHTML = '';
      empty.style.display = 'block';
      return;
    }
    empty.style.display = 'none';

    const html = filtered.map(function (p) {
      const chips = (p.matched_keywords || [])
        .map(function (k) { return '<span class="chip">' + escapeHtml(k) + '</span>'; })
        .join('');
      const authorLine = formatAuthors(p.authors);
      const journalLine = escapeHtml(p.journal || '');
      const publishedLine = p.published ? new Date(p.published).toLocaleDateString() : '';
      return ''
        + '<article class="paper">'
        +   '<div class="paper-head">'
        +     '<h2 class="paper-title"><a href="' + escapeHtml(p.url) + '" target="_blank" rel="noopener">' + escapeHtml(p.title) + '</a></h2>'
        +     '<span class="tier-badge ' + p.tier + '">' + p.final_score.toFixed(0) + '</span>'
        +   '</div>'
        +   '<div class="paper-meta">'
        +     (authorLine ? '<span>' + escapeHtml(authorLine) + '</span>' : '')
        +     (authorLine && journalLine ? '<span class="dot">&middot;</span>' : '')
        +     (journalLine ? '<span class="journal">' + journalLine + '</span>' : '')
        +     (publishedLine ? '<span class="dot">&middot;</span><span>' + publishedLine + '</span>' : '')
        +   '</div>'
        +   (p.abstract ? '<div class="paper-abstract">' + escapeHtml(p.abstract) + '</div>' : '')
        +   (chips ? '<div class="chips">' + chips + '</div>' : '')
        +   '<div class="score-detail">embedding ' + p.embedding_score.toFixed(0) + ' &middot; keywords ' + p.keyword_score.toFixed(0) + ' &middot; max cosine ' + p.max_cosine.toFixed(3) + '</div>'
        + '</article>';
    }).join('');
    list.innerHTML = html;

    // enable abstract expand on click
    list.querySelectorAll('.paper-abstract').forEach(function (el) {
      el.addEventListener('click', function () { el.classList.toggle('expanded'); });
    });
  }

  document.querySelectorAll('.tier-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.tier-btn').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeTier = btn.dataset.tier;
      render();
    });
  });

  let searchTimer = null;
  search.addEventListener('input', function (e) {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function () {
      searchTerm = e.target.value;
      render();
    }, 120);
  });

  render();
})();
</script>
</body>
</html>
